# Database Configuration (SQLite for development, PostgreSQL for production)
# For SQLite: sqlite:///./test.db
# For PostgreSQL: postgresql://username:password@localhost:5432/ai_singing_db
DATABASE_URL=sqlite:///./test.db
SQLALCHEMY_ECHO=False

# JWT Configuration
SECRET_KEY=your-secret-key-min-32-characters-long-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Server Configuration
DEBUG=True
HOST=0.0.0.0
PORT=8000

# Audio File Configuration
MAX_FILE_SIZE=52428800
ALLOWED_AUDIO_FORMATS=mp3,wav,m4a,flac,ogg
UPLOAD_DIR=uploads/audio

# ACRCloud Song Recognition (Get these from https://www.acrcloud.com/)
ACR_HOST=identify-eu-west-1.acrcloud.com
ACR_ACCESS_KEY=your-acrcloud-access-key
ACR_ACCESS_SECRET=your-acrcloud-access-secret
